{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/core.ts",
    "src/express/**/*",
    "src/next/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/index.ts",
    "src/types.ts",
    "src/verify.ts"
  ]
}
